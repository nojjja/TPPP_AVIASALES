<Window x:Class="AVIASALES.AdminLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Login"
        Height="301"
        Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Border Background="White" CornerRadius="8" Padding="18">
            <StackPanel>
                <TextBlock Text="Administrator Access" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                <TextBlock Text="Username"/>
                <TextBox x:Name="UsernameTextBox" Margin="0,4,0,10"/>
                <TextBlock Text="Password"/>
                <PasswordBox x:Name="PasswordTextBox" Margin="0,4,0,16" RenderTransformOrigin="0.5,0.5">
                    <PasswordBox.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform AngleX="2.732"/>
                            <RotateTransform/>
                            <TranslateTransform X="0.428"/>
                        </TransformGroup>
                    </PasswordBox.RenderTransform>
                </PasswordBox>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="80" Margin="0,0,10,0" Click="CancelButton_Click"/>
                    <Button Content="Login" Width="80" Click="LoginButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
