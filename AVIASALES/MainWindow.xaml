<Window x:Class="AVIASALES.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="✈ AVIASALES - Бронирование авиабилетов"
        Height="500"
        Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Ввод данных -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="📋 Детали бронирования" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                <TextBlock Text="Имя пассажира:"/>
                <TextBox x:Name="PassengerTextBox" Margin="0,0,0,10"/>

                <TextBlock Text="Выберите рейс:"/>
                <ComboBox x:Name="FlightsComboBox" Margin="0,0,0,10"/>

                <TextBlock Text="Класс обслуживания:"/>
                <ComboBox x:Name="ClassComboBox" Margin="0,0,0,10">
                    <ComboBoxItem Content="Economy"/>
                    <ComboBoxItem Content="Business"/>
                    <ComboBoxItem Content="First"/>
                </ComboBox>

                <!-- Опции -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox x:Name="BaggageCheckBox" Content="🧳 Багаж" Margin="0,0,20,0"/>
                    <CheckBox x:Name="MealCheckBox" Content="🍽 Питание" Margin="0,0,20,0"/>
                    <CheckBox x:Name="IsChildCheckBox" Content="👶 Ребенок"/>
                </StackPanel>

                <Button Content="✈ Забронировать билет" Click="BookButton_Click" Height="35"/>
            </StackPanel>
        </Border>

        <!-- История бронирований -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15">
            <StackPanel>
                <TextBlock Text="📜 История бронирований" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                <ListBox x:Name="BookingsListBox" Height="200" DisplayMemberPath="Summary" Margin="0,0,0,10"/>
                <Button Content="↺ Повторить выбранное бронирование" Click="CloneBookingButton_Click" Height="35" Background="#F39C12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>